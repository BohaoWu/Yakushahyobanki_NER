{
  "experiment_name": "quick_test",
  "description": "Quick validation: tests all code paths (SLM, CRF, BiLSTM, MLM pretrain, two-stage training, evaluation) with minimal epochs. Add LLaMA/remote LLM models manually if needed.",
  "models": [
    {
      "name": "bert",
      "model_id": "bert",
      "use_crf": false
    },
    {
      "name": "bert",
      "model_id": "bert_crf",
      "use_crf": true
    },
    {
      "name": "bilstm",
      "model_id": "bilstm",
      "use_crf": false
    }
  ],
  "data": {
    "datasets": [
      "dataset/yakusha_synthetic_topn5_uniform_chatgpt",
      "dataset/yakusha_annotated_data_few-shot"
    ],
    "epochs": [
      1,
      1
    ]
  },
  "training": {
    "batch_size": 4,
    "learning_rate": 2e-05,
    "seed": 42
  },
  "mlm_pretrain": {
    "enabled": true,
    "corpus": "synthetic_data/corpus_augment.txt",
    "corpus_size": 1000,
    "epochs": 1,
    "batch_size": 16,
    "learning_rate": 5e-05,
    "mlm_probability": 0.15
  },
  "output": {
    "dir": "experiments/quick_test_${timestamp}",
    "save_model": false
  },
  "advanced": {
    "run_in_background": false,
    "log_file": "logs/quick_test.log"
  },
  "evaluation": {
    "enabled": true,
    "output_dir": "experiments/quick_test_${timestamp}/evaluation_report"
  }
}
