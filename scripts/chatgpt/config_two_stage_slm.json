{
  "experiment_name": "two_stage_slm_top${topn}",
  "description": "Two-stage training: 1) Pre-train on synthetic data (N=${topn}) 2) Fine-tune on few-shot data",
  "models": [
    {
      "name": "bert",
      "model_id": "bert",
      "use_crf": false
    },
    {
      "name": "bert",
      "model_id": "bert_crf",
      "use_crf": true
    },
    {
      "name": "bert-large",
      "model_id": "bert_large",
      "use_crf": false
    },
    {
      "name": "bert-large",
      "model_id": "bert_large_crf",
      "use_crf": true
    },
    {
      "name": "roberta",
      "model_id": "roberta",
      "use_crf": false
    },
    {
      "name": "roberta",
      "model_id": "roberta_crf",
      "use_crf": true
    },
    {
      "name": "luke",
      "model_id": "luke",
      "use_crf": false
    },
    {
      "name": "luke",
      "model_id": "luke_crf",
      "use_crf": true
    },
    {
      "name": "albert",
      "model_id": "albert",
      "use_crf": false
    },
    {
      "name": "albert",
      "model_id": "albert_crf",
      "use_crf": true
    },
    {
      "name": "deberta",
      "model_id": "deberta",
      "use_crf": false
    },
    {
      "name": "deberta",
      "model_id": "deberta_crf",
      "use_crf": true
    },
    {
      "name": "bilstm",
      "model_id": "bilstm",
      "use_crf": false
    },
    {
      "name": "bilstm",
      "model_id": "bilstm_crf",
      "use_crf": true
    }
  ],
  "data": {
    "datasets": [
      "dataset/yakusha_synthetic_topn${topn}_uniform_chatgpt",
      "dataset/yakusha_annotated_data_few-shot"
    ],
    "epochs": [
      10,
      20
    ]
  },
  "training": {
    "batch_size": 64,
    "learning_rate": 2e-05,
    "seed": 42
  },
  "mlm_pretrain": {
    "enabled": false
  },
  "output": {
    "dir": "experiments/two_stage_slm_top${topn}_${timestamp}",
    "save_model": true
  },
  "advanced": {
    "run_in_background": false,
    "log_file": "logs/two_stage_slm_top${topn}.log"
  },
  "evaluation": {
    "enabled": true,
    "output_dir": "experiments/two_stage_slm_top${topn}_${timestamp}/evaluation_report"
  }
}
