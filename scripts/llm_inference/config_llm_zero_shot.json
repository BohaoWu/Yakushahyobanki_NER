      "few_shot_selection": "stratified"
    },
    {
      "name": "gpt-4o-mini",
      "model_id": "chatgpt_5shot",
      "provider": "chatgpt",
      "n_few_shot": 5,
      "few_shot_selection": "stratified"
    },
    {
      "name": "claude-3-haiku-20240307",
      "model_id": "claude_0shot",
      "provider": "claude",
      "n_few_shot": 0,
