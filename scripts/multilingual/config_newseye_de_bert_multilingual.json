{
  "experiment_name": "newseye_de_bert_multilingual",
  "description": "NewsEye German NER with multilingual BERT",
  "models": [
    {
      "name": "bert-multilingual",
      "model_id": "bert_multilingual",
      "use_crf": false
    },
    {
      "name": "bert-multilingual",
      "model_id": "bert_multilingual_crf",
      "use_crf": true
    }
  ],
  "data": {
    "datasets": [
      "dataset/Newseye/de"
    ],
    "epochs": [
      20
    ]
  },
  "training": {
    "batch_size": 32,
    "learning_rate": 2e-05,
    "seed": 42
  },
  "mlm_pretrain": {
    "enabled": false
  },
  "output": {
    "dir": "experiments/newseye_de_bert_multilingual_${timestamp}",
    "save_model": true
  },
  "advanced": {
    "run_in_background": false,
    "log_file": "logs/newseye_de_bert_multilingual.log"
  },
  "evaluation": {
    "enabled": true,
    "output_dir": "experiments/newseye_de_bert_multilingual_${timestamp}/evaluation_report"
  }
}
