{
  "experiment_name": "ajmc_de_two_stage_zero_shot",
  "description": "AJMC DE two-stage zero-shot: synthetic 10ep + real 20ep",
  "models": [
    { "name": "bert-english", "model_id": "bert_english", "use_crf": false },
    { "name": "bert-english", "model_id": "bert_english_crf", "use_crf": true },
    { "name": "bert-multilingual", "model_id": "mbert", "use_crf": false },
    { "name": "bert-multilingual", "model_id": "mbert_crf", "use_crf": true },
    { "name": "bert-german", "model_id": "bert_german", "use_crf": false },
    { "name": "bert-german", "model_id": "bert_german_crf", "use_crf": true }
  ],
  "data": {
    "datasets": ["dataset/ajmc_de_synthetic_ner_dataset_chatgpt_N_20", "dataset/AJMC/de"],
    "epochs": [10, 20],
    "split_mode": "zero_shot_entity"
  },
  "training": { "batch_size": 32, "learning_rate": 2e-05, "seed": 42 },
  "mlm_pretrain": { "enabled": false },
  "output": { "dir": "experiments/ajmc_de_two_stage_zero_shot_${timestamp}", "save_model": false },
  "advanced": { "run_in_background": false, "log_file": "logs/ajmc_de_two_stage_zero_shot.log" },
  "evaluation": { "enabled": false }
}
