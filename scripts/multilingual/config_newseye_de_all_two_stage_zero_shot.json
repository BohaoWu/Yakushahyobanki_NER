{
  "experiment_name": "newseye_de_all_two_stage_zero_shot_v2",
  "description": "NewsEye DE two-stage zero-shot entity v2: synthetic 10ep + real 20ep",
  "models": [
    { "name": "bert-multilingual", "model_id": "mbert", "use_crf": false },
    { "name": "bert-multilingual", "model_id": "mbert_crf", "use_crf": true },
    { "name": "bert-german", "model_id": "bert_german", "use_crf": false },
    { "name": "bert-german", "model_id": "bert_german_crf", "use_crf": true }
  ],
  "data": {
    "datasets": ["dataset/newseye_synthetic_ner_dataset_chatgpt_N_20", "dataset/Newseye/de"],
    "epochs": [10, 20],
    "split_mode": "zero_shot_entity"
  },
  "training": { "batch_size": 32, "learning_rate": 2e-05, "seed": 42 },
  "mlm_pretrain": { "enabled": false },
  "output": { "dir": "experiments/newseye_de_all_two_stage_zero_shot_v2_${timestamp}", "save_model": false },
  "advanced": { "run_in_background": false, "log_file": "logs/newseye_de_all_two_stage_zero_shot_v2.log" },
  "evaluation": { "enabled": false }
}
